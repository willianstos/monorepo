# Provider Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# Workspace Runtime
DEFAULT_MODEL=
DEFAULT_PROJECT=01-template-project
ALLOW_SHELL=false
MAX_GRAPH_ITERATIONS=3

# Hybrid Windows + WSL Contract
HYBRID_WSL_DISTRO=Ubuntu-24.04
HYBRID_WSL_USER=will
HYBRID_WSL_DEV_HOME=/home/will/projetos
HYBRID_GITEA_URL=http://localhost:3001
HYBRID_GITEA_SSH_URL=ssh://git@localhost:222
HYBRID_GITEA_OPS_DIR=/home/will/projetos/gitea-wsl-ops

# Local Gitea Stack
GITEA_IMAGE_TAG=1.25.4
POSTGRES_IMAGE_TAG=15.17-alpine
BACKUP_HELPER_IMAGE=alpine:3.22.1
GITEA_DB_USER=gitea
GITEA_DB_NAME=gitea
GITEA_DB_PASSWORD=
GITEA_HTTP_PORT=3001
GITEA_SSH_PORT=222
GITEA_DOMAIN=localhost
GITEA_SSH_DOMAIN=localhost
GITEA_ROOT_URL=http://localhost:3001/
GITEA_DISABLE_REGISTRATION=true
GITEA_SECRET_KEY=
GITEA_INTERNAL_TOKEN=
GITEA_JWT_SECRET=
GITEA_ADMIN_USER=admin
GITEA_ADMIN_PASSWORD=
GITEA_ADMIN_EMAIL=admin@localhost
TZ=America/Sao_Paulo
