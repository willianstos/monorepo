{
  "mcpServers": {
    "future-agents-local": {
      "command": "wsl.exe",
      "args": [
        "-d",
        "Ubuntu-24.04",
        "bash",
        "--noprofile",
        "--norc",
        "-lc",
        "cd /mnt/c/Users/Zappro/repos/01-monorepo && exec bash bootstrap/mcp-launch-future-agents.sh"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "startup_timeout_sec": 120
    },
    "docker": {
      "command": "wsl.exe",
      "args": [
        "-d",
        "Ubuntu-24.04",
        "bash",
        "--noprofile",
        "--norc",
        "-lc",
        "cd /mnt/c/Users/Zappro/repos/01-monorepo && exec bash bootstrap/mcp-launch-docker.sh"
      ],
      "env": {
        "DOCKER_HOST": "unix:///var/run/docker.sock"
      },
      "startup_timeout_sec": 40
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@cyanheads/git-mcp-server@2.10.0"
      ],
      "startup_timeout_sec": 30
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-fetch"
      ],
      "startup_timeout_sec": 20
    },
    "redis": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-redis@2025.4.25",
        "redis://127.0.0.1:6380"
      ],
      "startup_timeout_sec": 40
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "C:\\Users\\Zappro\\repos\\codex-mcp-server",
        "C:\\Users\\Zappro\\repos"
      ],
      "startup_timeout_sec": 30
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@2.1.2"
      ],
      "startup_timeout_sec": 30
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@0.2.17"
      ],
      "startup_timeout_sec": 30
    },
    "TestSprite": {
      "command": "npx",
      "args": [
        "-y",
        "@testsprite/testsprite-mcp@0.0.30"
      ],
      "startup_timeout_sec": 30
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@0.19.0"
      ],
      "startup_timeout_sec": 20
    },
    "ai-context": {
      "command": "npx",
      "args": [
        "--yes",
        "@ai-coders/context@0.7.1",
        "mcp"
      ],
      "startup_timeout_sec": 30
    }
  }
}
